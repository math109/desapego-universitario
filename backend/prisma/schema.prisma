generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  nome      String
  email     String    @unique
  senha     String    
  anuncios  Anuncio[] 
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Anuncio {
  id          String   @id @default(uuid())
  titulo      String
  descricao   String
  categoria   String   
  preco       Float?   
  imagemUrl   String   
  usuarioId   String
  usuario     User     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}